{
  "name": "web-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test": "npm run test:unit -- --run",
    "test:unit": "vitest",
    "build-only": "vite build",
    "generate:local-api-types": "jiti scripts/generate-local-api-types.mts write",
    "check:local-api-types": "jiti scripts/generate-local-api-types.mts check",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@tanstack/vue-query": "^5.90.5",
    "@yume-chan/scrcpy": "^2.1.1",
    "@yume-chan/scrcpy-decoder-webcodecs": "^2.1.1",
    "cron-parser": "^5.5.0",
    "openapi-fetch": "^0.17.0",
    "radix-vue": "^1.9.17",
    "vue": "^3.5.32",
    "vue-i18n": "^11.1.12",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "openapi-typescript": "^7.13.0",
    "oxlint": "~1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
